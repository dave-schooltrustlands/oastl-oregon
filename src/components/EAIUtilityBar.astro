---
// EAI Utility Bar — OASTL chapter variant.
// Left says "Eighth Anchor Institute → OASTL Oregon Chapter — you are here".
// Right is a dropdown listing the campus buildings; Oregon Chapter is non-link.
const buildings = [
  { label: 'The Library',                  href: 'https://schooltrusts.net',     comingSoon: false },
  { label: 'ASTL National',                href: 'https://schooltrustlands.net', comingSoon: false },
  { label: 'Oregon Chapter',               href: null,                            comingSoon: false, youAreHere: true },
  { label: 'ORWW Field Station',           href: 'http://orww.org',               comingSoon: false },
  { label: 'The Eighth Anchor Institute',  href: 'https://eighthanchor.org',     comingSoon: false },
];
---
<div class="eai-utility-bar" data-component="eai-utility-bar">
  <div class="eai-utility-bar__inner">
    <div class="eai-utility-bar__left" aria-label="You are at OASTL — the Oregon Chapter of the Eighth Anchor Institute">
      <svg
        class="eai-utility-bar__mark"
        viewBox="0 0 24 24"
        width="14"
        height="14"
        aria-hidden="true"
        focusable="false"
      >
        <circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="1.1" />
        <line x1="12" y1="2.5" x2="12" y2="21.5" stroke="currentColor" stroke-width="0.8" />
        <line x1="2.5" y1="12" x2="21.5" y2="12" stroke="currentColor" stroke-width="0.8" />
        <circle cx="12" cy="12" r="2.2" fill="currentColor" />
      </svg>
      <a class="eai-utility-bar__parent" href="https://eighthanchor.org">The Eighth Anchor Institute</a>
      <span class="eai-utility-bar__sep" aria-hidden="true">→</span>
      <span class="eai-utility-bar__name">OASTL Oregon Chapter</span>
      <span class="eai-utility-bar__you-are-here" aria-hidden="true">— you are here</span>
    </div>

    <div class="eai-utility-bar__right">
      <details class="eai-utility-bar__dropdown">
        <summary>
          Campus buildings
          <span class="eai-utility-bar__chev" aria-hidden="true">▾</span>
        </summary>
        <ul class="eai-utility-bar__menu" role="menu">
          {buildings.map((b) => (
            <li role="none">
              {!b.href ? (
                <span class="eai-utility-bar__item eai-utility-bar__item--here" role="menuitem" aria-current="page">
                  {b.label}
                  <span class="eai-utility-bar__tag">you are here</span>
                </span>
              ) : (
                <a class="eai-utility-bar__item" href={b.href} role="menuitem">
                  {b.label}
                </a>
              )}
            </li>
          ))}
        </ul>
      </details>
    </div>
  </div>
</div>

<style>
  .eai-utility-bar {
    background: #0E1A24;
    color: #F4EFE4;
    border-bottom: 1px solid rgba(244, 239, 228, 0.10);
    font-family: 'IBM Plex Mono', 'SF Mono', Menlo, Consolas, monospace;
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    position: relative;
    z-index: 40;
  }
  .eai-utility-bar__inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 1.25rem;
    height: 30px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .eai-utility-bar__left {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-width: 0;
  }
  .eai-utility-bar__mark { color: #C89B2E; flex-shrink: 0; }
  .eai-utility-bar__parent {
    color: rgba(244, 239, 228, 0.75);
    text-decoration: none;
    white-space: nowrap;
  }
  .eai-utility-bar__parent:hover { color: #C89B2E; }
  .eai-utility-bar__sep { color: rgba(244, 239, 228, 0.45); }
  .eai-utility-bar__name {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: #F4EFE4;
  }
  .eai-utility-bar__you-are-here {
    color: rgba(244, 239, 228, 0.55);
    margin-left: 0.25rem;
  }
  @media (max-width: 720px) {
    .eai-utility-bar__parent,
    .eai-utility-bar__sep,
    .eai-utility-bar__you-are-here { display: none; }
  }
  .eai-utility-bar__right { display: flex; align-items: center; }
  .eai-utility-bar__dropdown { position: relative; }
  .eai-utility-bar__dropdown > summary {
    cursor: pointer;
    list-style: none;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: #F4EFE4;
    padding: 4px 0;
  }
  .eai-utility-bar__dropdown > summary::-webkit-details-marker { display: none; }
  .eai-utility-bar__dropdown > summary:hover { color: #C89B2E; }
  .eai-utility-bar__chev {
    font-size: 9px;
    letter-spacing: 0;
    transition: transform 120ms ease;
  }
  .eai-utility-bar__dropdown[open] .eai-utility-bar__chev { transform: rotate(180deg); }
  .eai-utility-bar__menu {
    position: absolute;
    right: 0;
    top: calc(100% + 4px);
    min-width: 240px;
    background: #0E1A24;
    border: 1px solid rgba(244, 239, 228, 0.15);
    list-style: none;
    margin: 0;
    padding: 6px 0;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35);
  }
  .eai-utility-bar__item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 7px 14px;
    color: #F4EFE4;
    text-decoration: none;
    font-size: 10px;
    letter-spacing: 0.14em;
  }
  a.eai-utility-bar__item:hover { background: rgba(244, 239, 228, 0.06); color: #C89B2E; }
  .eai-utility-bar__item--here { color: rgba(244, 239, 228, 0.55); cursor: default; }
  .eai-utility-bar__tag {
    font-size: 8px;
    letter-spacing: 0.18em;
    color: #C89B2E;
    border: 1px solid rgba(200, 155, 46, 0.40);
    padding: 1px 5px;
  }
</style>

<script type="module" is:inline>
  document.addEventListener('click', (e) => {
    document.querySelectorAll('.eai-utility-bar__dropdown[open]').forEach((d) => {
      if (!d.contains(e.target)) d.removeAttribute('open');
    });
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      document.querySelectorAll('.eai-utility-bar__dropdown[open]').forEach((d) => d.removeAttribute('open'));
    }
  });
</script>
