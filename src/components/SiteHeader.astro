---
const nav = [
  { label: 'Briefing Room',   href: '/briefing-room/' },
  { label: 'Legal Desk',      href: '/legal-desk/' },
  { label: 'Ask OASTL',       href: '/ask/' },
  { label: 'Field Notes',     href: '/field-notes/' },
  { label: 'Our Board',       href: '/coalition-table/' },
  { label: 'Founding Texts',  href: '/founding-texts/' },
  { label: 'Governance',      href: '/governance/' },
  { label: 'Students',        href: '/students/' },
  { label: 'Join',            href: '/join/' },
  { label: 'Donate',          href: '/donate/' },
];

const current = Astro.url?.pathname || '/';
---
<div class="eai-utility-bar bg-oastl-ink text-oastl-cream/80 border-b border-oastl-gold/20 text-xs">
  <div class="mx-auto max-w-6xl px-5 py-2 flex flex-col gap-2 md:flex-row md:items-center md:justify-between">
    <span class="font-mono uppercase tracking-[0.18em] text-oastl-gold">School Trust Public Record</span>
    <nav class="flex flex-wrap items-center gap-x-4 gap-y-1" aria-label="School trust network links">
      <a href="https://schooltrusts.net/" class="hover:text-oastl-gold">National Library</a>
      <a href="https://schooltrustlands.net/" class="hover:text-oastl-gold">ASTL National</a>
      <a href="https://orww.org/" class="hover:text-oastl-gold">Oregon Watershed Record</a>
      <a href="https://eighthanchor.org/" class="hover:text-oastl-gold">Eighth Anchor</a>
    </nav>
  </div>
</div>

<header class="border-b border-oastl-forest/20 bg-oastl-bone/95 backdrop-blur sticky top-0 z-30">
  <div class="mx-auto max-w-6xl px-5 py-4 flex flex-col md:flex-row md:items-center md:justify-between gap-3">
    <a href="/" class="flex items-center gap-3 group" aria-label="OASTL home">
      <img
        src="/brand/oastl-lockup.png"
        srcset="/brand/oastl-lockup-48.png 1x, /brand/oastl-lockup-96.png 2x"
        alt="Oregon Advocates for School Trust Lands"
        width="330"
        height="96"
        loading="eager"
        decoding="async"
        class="h-12 w-auto transition-opacity group-hover:opacity-90"
      />
    </a>
    <nav class="text-sm flex flex-wrap items-center gap-x-5 gap-y-2">
      {nav.map((item) => {
        const isCurrent = current === item.href || (item.href !== '/' && current.startsWith(item.href));
        const isDonate = item.label === 'Donate';
        if (isDonate) {
          return (
            <a
              href={item.href}
              class="inline-flex items-center gap-1 rounded-sm border border-oastl-gold bg-oastl-gold/10 px-3 py-1 text-oastl-forest font-medium hover:bg-oastl-gold hover:text-white transition-colors"
            >
              {item.label}
            </a>
          );
        }
        return (
          <a
            href={item.href}
            class:list={[
              'hover:text-oastl-gold transition-colors',
              isCurrent ? 'text-oastl-forest font-semibold border-b-2 border-oastl-gold pb-0.5' : 'text-oastl-ink/80',
            ]}
          >
            {item.label}
          </a>
        );
      })}
    </nav>
  </div>
</header>
