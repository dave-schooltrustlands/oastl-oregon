---
import EAIUtilityBar from '../components/EAIUtilityBar.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

export interface Props {
  title: string;
  description?: string;
  path?: string;
  ogTitle?: string;
  ogDescription?: string;
}

const SITE = 'https://oastl.org';

const {
  title,
  description = 'OASTL — Oregon Advocates for School Trust Lands. Enforcing Oregon’s constitutional duties to public schools.',
  path = Astro.url?.pathname || '/',
  ogTitle,
  ogDescription,
} = Astro.props;

const canonical = new URL(path, SITE).toString();
const ogImage = new URL('/og-image.svg', SITE).toString();
const resolvedOgTitle = ogTitle || title;
const resolvedOgDescription = ogDescription || description;
---
<!doctype html>
<html lang="en" class="bg-oastl-bone text-oastl-ink">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="OASTL — Oregon Advocates for School Trust Lands" />
    <meta property="og:title" content={resolvedOgTitle} />
    <meta property="og:description" content={resolvedOgDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedOgTitle} />
    <meta name="twitter:description" content={resolvedOgDescription} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,500;1,600&family=IBM+Plex+Mono:wght@400;500&family=Inter:wght@400;500;600;700&display=swap"
    />
  </head>
  <body class="font-sans antialiased min-h-screen flex flex-col bg-oastl-bone">
    <EAIUtilityBar />
    <SiteHeader />
    <main class="flex-1">
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
