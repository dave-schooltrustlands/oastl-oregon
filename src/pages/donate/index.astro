---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
---
<BaseLayout
  title="Donate · OASTL"
  description="Donations to OASTL — a 501(c)(3) Oregon nonprofit — fund the litigation, scholarship, and coalition work that hold Oregon to its constitutional duties to public schools."
  path="/donate/"
>
  <PageHero
    eyebrow="Donate"
    title="Fund the case. Fund the recovery."
    dek="OASTL is a 501(c)(3) Oregon nonprofit. Donations fund the litigation, the scholarship, and the coalition work."
  />

  <section class="bg-oastl-bone">
    <div class="mx-auto max-w-3xl px-5 py-16">
      <div class="border border-oastl-forest/20 bg-oastl-cream rounded-sm p-8">
        <div class="font-mono text-[10px] tracking-[0.22em] uppercase text-oastl-gold mb-3">
          Donate · v1
        </div>
        <h2 class="font-serif text-2xl md:text-3xl text-oastl-forest font-semibold leading-tight">
          Payment integration arrives with v1.1.
        </h2>
        <p class="mt-4 text-oastl-ink/85 leading-relaxed">
          For v1, please email <a href="mailto:info@oastl.org" class="text-oastl-action hover:text-oastl-gold underline decoration-oastl-gold/40">info@oastl.org</a> for donor instructions — including check, wire, and donor-advised-fund routing. A self-serve donation form will be added once Stripe is wired.
        </p>
        <p class="mt-3 text-sm text-oastl-ink/60">
          OASTL is a 501(c)(3) nonprofit private foundation; donations are deductible to the extent allowed by law. IRS determination letter on file.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
