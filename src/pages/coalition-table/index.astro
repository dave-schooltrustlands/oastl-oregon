---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';

const board = [
  {
    name: 'Dave Sullivan, Ph.D. & Barb Sullivan',
    role: 'President & Treasurer',
    bio: 'Dave brings a background in systems analysis and public service and co-authored <em>Oregon’s Constitutional Duties to Schools</em> (2025). Barb oversees OASTL’s financial compliance and resource management and created the OASTL logo. They are small woodland owners who live on their 200-acre tree farm in Kings Valley.',
    contact: '<a href="mailto:drdavesullivan@gmail.com" class="underline decoration-oastl-gold/60 hover:text-oastl-gold">drdavesullivan@gmail.com</a> · <a href="mailto:barbaraksullivan@yahoo.com" class="underline decoration-oastl-gold/60 hover:text-oastl-gold">barbaraksullivan@yahoo.com</a> · 541-791-6470',
    photo: '/images/board/dave-and-barb-sullivan.jpg',
    photoAlt: 'Dave and Barb Sullivan',
    photoPosition: 'center center',
  },
  {
    name: 'Laura D. Cooper',
    role: 'Board Member, Attorney · OSB# 863589',
    bio: 'Decades of high-level legal experience in civil rights and complex litigation. Former General Counsel for the Pain Relief Network. Counsel for additional civil rights organizations.',
    pullquote: '“As an attorney, you rarely see a constitutional question this clean and ready for adjudication.”',
    photo: '/images/board/daniel-crowe.png',
    photoAlt: 'Laura D. Cooper',
    photoPosition: 'center top',
  },
  {
    name: 'Margaret Bird',
    role: 'Board Member · School-trust-lands scholar',
    bio: 'Economist and nationally recognized school trust lands expert based in Utah. Co-founder of national Advocates for School Trust Lands. Co-author of <em>Oregon’s Constitutional Duties to Schools</em> (2025) with Dave Sullivan. Led the historic reform of Utah’s school trust lands.',
    photo: '/images/board/laura-cooper.jpg',
    photoAlt: 'Margaret Bird',
    photoPosition: 'center top',
  },
  {
    name: 'Bob Zybach, Ph.D.',
    role: 'Secretary',
    bio: 'Forest and wildfire historian. Maintainer of the ORWW (Oregon Websites and Watersheds Project) archive, which keeps Jerry Phillips’s Elliott book online and free. Co-founder of Phoenix Reforestation. Decades of research on Pacific Northwest forest history.',
    photo: '/images/board/bob-zybach.jpg',
    photoAlt: 'Bob Zybach',
    photoPosition: 'center top',
  },
];

const memoriam = {
  name: 'David Gould',
  dates: '1942–2024',
  role: 'Past President',
  bio: 'The heart and soul of OASTL, David served as its president throughout 2023. A great-grandchild of an early Oregon homesteader, he carried the history of the land in person.',
  photo: '/images/board/david-gould-memorial.jpg',
  photoAlt: 'David Gould',
  photoPosition: 'center top',
};
---
<BaseLayout
  title="Coalition Table · OASTL"
  description="The OASTL Board of Directors — volunteers enforcing Oregon’s constitutional duties to public schools."
  path="/coalition-table/"
>
  <PageHero
    eyebrow="Our Board — at the Coalition Table"
    title="Volunteers, accountable to the beneficiaries."
    dek="OASTL is governed by volunteers dedicated to enforcing Oregon’s constitutional duties to public schools. The board brings together expertise in constitutional law, forestry science, trust management, and education policy."
  />

  <section class="bg-oastl-bone">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="font-mono text-[11px] tracking-[0.22em] uppercase text-oastl-forest mb-2">
        Board of Directors
      </div>
      <h2 class="font-serif text-3xl md:text-4xl text-oastl-ink font-semibold leading-tight mb-10">
        Named members of the OASTL board.
      </h2>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {board.map((m) => (
          <article class="border border-oastl-forest/20 bg-oastl-cream rounded-sm p-6 flex flex-col">
            <div class="aspect-[4/5] w-full mb-4 rounded-sm border border-oastl-forest/20 bg-oastl-bone overflow-hidden">
              <img
                src={m.photo}
                alt={m.photoAlt}
                loading="lazy"
                class="w-full h-full object-cover"
                style={`object-position: ${m.photoPosition};`}
              />
            </div>
            <h3 class="font-serif text-2xl text-oastl-forest font-semibold leading-tight">{m.name}</h3>
            <div class="mt-1 font-mono text-[10px] tracking-[0.22em] uppercase text-oastl-gold">
              {m.role}
            </div>
            <p class="mt-4 text-[15px] text-oastl-ink/85 leading-relaxed" set:html={m.bio} />
            {m.pullquote && (
              <blockquote class="mt-4 border-l-2 border-oastl-gold pl-3 text-[15px] italic text-oastl-ink/80 leading-relaxed">
                {m.pullquote}
              </blockquote>
            )}
            {m.contact && (
              <div class="mt-4 pt-3 border-t border-oastl-forest/10 text-sm text-oastl-ink/70" set:html={m.contact} />
            )}
          </article>
        ))}
      </div>

      <!-- In Memoriam -->
      <div class="mt-14">
        <div class="font-mono text-[11px] tracking-[0.22em] uppercase text-oastl-blueprint mb-3">
          In Memoriam
        </div>
        <article class="border border-oastl-blueprint/30 bg-oastl-bone/70 rounded-sm p-6 md:p-8 grid gap-6 md:grid-cols-[180px,1fr] items-start">
          <div class="aspect-[4/5] w-full rounded-sm border border-oastl-blueprint/30 bg-oastl-cream/50 overflow-hidden">
            <img
              src={memoriam.photo}
              alt={memoriam.photoAlt}
              loading="lazy"
              class="w-full h-full object-cover saturate-50"
              style={`object-position: ${memoriam.photoPosition};`}
            />
          </div>
          <div>
            <h3 class="font-serif text-2xl text-oastl-ink font-semibold leading-tight">{memoriam.name}</h3>
            <div class="mt-1 font-mono text-[11px] tracking-[0.22em] uppercase text-oastl-blueprint">
              {memoriam.dates} · {memoriam.role}
            </div>
            <p class="mt-4 text-[15px] text-oastl-ink/80 leading-relaxed italic">In Memoriam · {memoriam.dates}</p>
            <p class="mt-3 text-[15px] text-oastl-ink/80 leading-relaxed">{memoriam.bio}</p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- Join Our Coalition -->
  <section class="bg-oastl-cream/40 border-t border-oastl-forest/15">
    <div class="mx-auto max-w-4xl px-5 py-16">
      <div class="font-mono text-[11px] tracking-[0.22em] uppercase text-oastl-forest mb-2">
        Join Our Coalition
      </div>
      <h2 class="font-serif text-2xl md:text-3xl text-oastl-ink font-semibold leading-tight">
        We invite inquiries from prospective board members.
      </h2>
      <p class="mt-4 text-oastl-ink/85 leading-relaxed">
        OASTL seeks to represent a diverse cross-section of Oregonians.
      </p>
      <ul class="mt-6 grid gap-4 md:grid-cols-3">
        <li class="border border-oastl-forest/20 bg-oastl-bone rounded-sm p-5">
          <div class="font-mono text-[10px] tracking-[0.22em] uppercase text-oastl-gold mb-2">Education</div>
          <p class="text-[15px] text-oastl-ink/80 leading-relaxed">Students, Teachers, School Board Members, and Administrators.</p>
        </li>
        <li class="border border-oastl-forest/20 bg-oastl-bone rounded-sm p-5">
          <div class="font-mono text-[10px] tracking-[0.22em] uppercase text-oastl-gold mb-2">Forestry & Industry</div>
          <p class="text-[15px] text-oastl-ink/80 leading-relaxed">Foresters, Tree Farm Owners, and Forest Industry Professionals.</p>
        </li>
        <li class="border border-oastl-forest/20 bg-oastl-bone rounded-sm p-5">
          <div class="font-mono text-[10px] tracking-[0.22em] uppercase text-oastl-gold mb-2">Government</div>
          <p class="text-[15px] text-oastl-ink/80 leading-relaxed">Current or former employees of the Department of Education or Forestry.</p>
        </li>
      </ul>

      <div class="mt-8 border border-oastl-forest/20 bg-oastl-cream rounded-sm p-6">
        <div class="font-mono text-[10px] tracking-[0.22em] uppercase text-oastl-forest mb-2">Contact Us</div>
        <p class="text-[15px] text-oastl-ink/85 leading-relaxed">
          <strong>Dave Sullivan, President.</strong><br />
          Email: <a href="mailto:drdavesullivan@gmail.com" class="text-oastl-action hover:text-oastl-gold underline decoration-oastl-gold/40">drdavesullivan@gmail.com</a><br />
          Phone/Text: 541-791-6470
        </p>
      </div>

      <div class="mt-10 border border-oastl-forest/15 bg-oastl-cream/40 rounded-sm p-6 text-sm text-oastl-ink/80">
        <strong class="text-oastl-forest">Governance note.</strong>
        OASTL board members are volunteers. They receive no compensation. Bylaws are modeled after the bylaws of Advocates for School Trust Lands (ASTL) National. See <a href="/governance/" class="text-oastl-action hover:text-oastl-gold underline decoration-oastl-gold/40">Governance &amp; Founding Documents</a> for the IRS 501(c)(3) determination letter and the bylaws PDF.
      </div>
    </div>
  </section>
</BaseLayout>
