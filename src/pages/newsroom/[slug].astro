---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

type Props = { entry: CollectionEntry<'newsroom'> };

export async function getStaticPaths() {
  const entries = await getCollection('newsroom');
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props as Props;
const { Content } = await entry.render();

const dateFormatter = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---
<BaseLayout
  title={`${entry.data.title} · Newsroom · OASTL`}
  description={entry.data.kicker.replace(/<[^>]+>/g, '')}
  path={`/newsroom/${entry.slug}/`}
>
  <article class="mx-auto max-w-3xl px-5 py-12">
    <header class="mb-8 pb-6 border-b border-oastl-forest/20">
      <p class="font-mono text-[11px] tracking-[0.22em] uppercase text-oastl-ink/60 mb-2">
        <a href="/newsroom/" class="hover:text-oastl-forest">Newsroom</a>
        <span class="mx-1">·</span>
        <span>{dateFormatter.format(entry.data.date)}</span>
        <span class="mx-1">·</span>
        <span class="text-oastl-forest">{entry.data.cadence}</span>
      </p>
      <h1 class="font-serif text-3xl sm:text-4xl text-oastl-forest leading-tight font-semibold">
        {entry.data.title}
      </h1>
      <p
        class="mt-4 font-serif text-base sm:text-lg text-oastl-ink/85 leading-relaxed"
        set:html={entry.data.kicker}
      />
    </header>

    <div class="prose prose-lg max-w-none font-serif text-oastl-ink
                prose-headings:font-serif prose-headings:text-oastl-forest
                prose-a:text-oastl-action prose-a:underline hover:prose-a:text-oastl-forest
                prose-strong:text-oastl-ink prose-em:text-oastl-ink">
      <Content />
    </div>

    <hr class="my-10 border-oastl-forest/20" />

    <p class="font-sans text-sm text-oastl-ink/60 leading-relaxed italic">
      The Newsroom is the national newsletter of Advocates for School Trust
      Lands. Published weekly Mondays with a monthly summary mid-month.
      Each edition reads on
      <a href="https://schooltrustlands.net/newsroom/" class="text-oastl-action underline hover:text-oastl-forest">schooltrustlands.net/newsroom/</a>
      and here on OASTL Oregon. Subscribe at either property.
    </p>

    <p class="mt-8">
      <a href="/newsroom/" class="font-sans text-sm text-oastl-forest underline hover:text-oastl-gold">
        ← All Newsroom issues
      </a>
    </p>
  </article>
</BaseLayout>
