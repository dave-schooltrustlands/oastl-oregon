---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Not found · OASTL"
  description="The page you were looking for isn’t on OASTL."
  path="/404"
>
  <section class="bg-oastl-bone">
    <div class="mx-auto max-w-3xl px-5 py-24 text-center">
      <div class="font-mono text-[11px] tracking-[0.22em] uppercase text-oastl-gold mb-3">404</div>
      <h1 class="font-serif text-4xl md:text-5xl text-oastl-forest font-semibold leading-tight">
        That page isn’t here.
      </h1>
      <p class="mt-5 text-oastl-ink/80 leading-relaxed">
        If you followed a link that broke, please let us know at <a href="mailto:dave.sullivan@oastl.org" class="underline decoration-oastl-gold/60 hover:text-oastl-gold">dave.sullivan@oastl.org</a>.
      </p>
      <a
        href="/"
        class="mt-8 inline-flex items-center gap-2 bg-oastl-forest text-oastl-cream px-5 py-3 rounded-sm font-medium hover:bg-oastl-canopy"
      >
        ← Return to the OASTL home
      </a>
    </div>
  </section>
</BaseLayout>
