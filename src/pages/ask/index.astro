---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Ask OASTL · Oregon Advocates for School Trust Lands';
const description =
  "Questions about Oregon's school trust lands, answered from OASTL's verified Oregon source record. The public search desk is being connected; source links are available now.";
---
<BaseLayout title={title} description={description} path="/ask/">
  <section class="relative bg-oastl-forest text-oastl-cream overflow-hidden">
    <div class="relative mx-auto max-w-3xl px-5 py-14 sm:py-18">
      <div class="font-mono text-[11px] tracking-[0.22em] uppercase text-oastl-gold mb-3">
        OASTL · Ask
      </div>
      <h1 class="font-serif text-4xl md:text-5xl font-semibold leading-tight tracking-tight">
        Ask OASTL
      </h1>
      <p class="mt-4 font-serif italic text-lg text-oastl-cream/90 max-w-2xl leading-snug">
        The public search desk is being connected.
      </p>
      <p class="mt-5 font-sans text-base text-oastl-cream/85 max-w-2xl leading-relaxed">
        OASTL is preparing a question-and-answer search surface for Oregon's school-trust record.
        Until it is live, start with the source links below or contact OASTL directly. For broader national context, see
        <a href="https://schooltrustlands.net/ask/" class="text-oastl-gold underline hover:text-oastl-cream">
          Ask ASTL
        </a>
        on the national coalition's site.
      </p>
    </div>
  </section>

  <section class="bg-oastl-bone border-t border-oastl-forest/20">
    <div class="mx-auto max-w-3xl px-5 py-10 sm:py-12">
      <div class="border border-oastl-forest/20 bg-oastl-cream rounded-sm p-6">
        <div class="font-mono text-[11px] tracking-[0.22em] uppercase text-oastl-forest mb-3">
          Coming online
        </div>
        <p class="font-serif text-xl text-oastl-ink leading-snug">
          Ask OASTL will answer public questions from OASTL's verified Oregon source record once the search service is authorized.
        </p>
        <p class="mt-4 text-sm text-oastl-ink/75 leading-relaxed">
          The future search surface will decline individual legal advice, off-topic questions, and predictions about active litigation. For individual legal questions about your situation, contact OASTL's General Counsel through the
        <a href="/coalition-table/" class="text-oastl-action underline hover:text-oastl-forest">Coalition Table</a>.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-oastl-cream/40 border-y border-oastl-forest/15">
    <div class="mx-auto max-w-3xl px-5 py-12">
      <div class="font-mono text-[11px] tracking-[0.22em] uppercase text-oastl-forest mb-3">
        Or browse the record
      </div>
      <h2 class="font-serif text-2xl text-oastl-forest font-semibold mb-4">
        Where else to start
      </h2>
      <ul class="font-sans text-sm space-y-2">
        <li>
          <a href="/briefing-room/" class="text-oastl-action underline hover:text-oastl-forest">Briefing Room</a>
          — Oregon's Common School Fund, Elliott State Forest, the legal record.
        </li>
        <li>
          <a href="/legal-desk/" class="text-oastl-action underline hover:text-oastl-forest">Legal Desk</a>
          — active case, six trustee duties, Evidence Locker, Daniel Crowe's filings.
        </li>
        <li>
          <a href="/coalition-table/" class="text-oastl-action underline hover:text-oastl-forest">Coalition Table</a>
          — board, leadership, how to reach the General Counsel.
        </li>
        <li>
          <a href="/founding-texts/" class="text-oastl-action underline hover:text-oastl-forest">Founding Texts</a>
          — <em>Oregon's Constitutional Duties to Schools</em>.
        </li>
      </ul>
    </div>
  </section>
</BaseLayout>
