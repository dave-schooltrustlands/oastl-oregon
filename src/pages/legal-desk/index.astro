  <!-- Section 8 — Board of Director's Perspective: Laura Cooper -->
  <section class="bg-oastl-cream/40 border-y border-oastl-forest/15">
    <div class="mx-auto max-w-4xl px-5 py-16">
      <div class="font-mono text-[11px] tracking-[0.22em] uppercase text-oastl-forest mb-2">
        Section 8 · Board of Director’s Perspective
      </div>
      <h2 class="font-serif text-3xl md:text-4xl text-oastl-ink font-semibold leading-tight">
        Laura D. Cooper, OSB# 863589
      </h2>

      <LedgerCard tone="bone" class="mt-6">
        <div class="grid gap-6 md:grid-cols-[160px,1fr] items-start">
          <div class="aspect-[4/5] w-full rounded-sm border border-oastl-forest/20 bg-oastl-cream overflow-hidden">
            <img
              src="/images/board/daniel-crowe.png"
              alt="Laura D. Cooper"
              loading="lazy"
              class="w-full h-full object-cover"
              style="object-position: center top;"
            />
          </div>
          <div class="space-y-4 text-[16px] leading-relaxed">
            <p>
              Ms. Cooper serves on the OASTL Board of Directors. She brings decades of high-level legal experience in civil rights and complex litigation. She is a former General Counsel for the Pain Relief Network and counsel for additional civil rights organizations.
            </p>

