---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import FoundingBookCard from '../../components/FoundingBookCard.astro';
---
<BaseLayout
  title="Founding Texts · OASTL"
  description="Oregon’s Constitutional Duties to Schools (2025) by Margaret Bird and Dave Sullivan — OASTL’s founding scholarship."
  path="/founding-texts/"
>
  <PageHero
    eyebrow="Founding Texts"
    title="The scholarship that grounds the litigation."
    dek="OASTL’s founding text — the legal and historical case for Oregon’s accountability."
  />

  <section class="bg-oastl-bone">
    <div class="mx-auto max-w-4xl px-5 py-16">
      <FoundingBookCard variant="full" />
    </div>
  </section>
</BaseLayout>
